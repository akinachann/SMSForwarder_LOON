#!name = 短信转发Loon版(iOS<17)
#!desc = MitM->腾讯手机管家->获取短信->转发
#!author = akinachan & Gemini & Claude
#!version = 2.4.0
#!date = 2026-03-26
#!homePage = https://github.com/akinachann/SMSForwarder_LOON
#!icon = https://raw.githubusercontent.com/pppscn/SmsForwarder/refs/heads/main/pic/SmsForwarder.png
#!tag = 短信转发, 验证码, 自动化

[General]
description = 自动转发短信验证码到Telegram或飞书，在下方填入对应平台的Token即可启用。同时填写即可同时转发。
update-interval = 86400
timeout = 30

[Argument]
tg_token = input,"格式为：123456789:AAFxxxxxxx.-100123456789",tag=Telegram配置,desc=格式为: BotToken.ChatID (留空则不转发到Telegram)
feishu_token = input,"",tag=飞书配置,desc=填入完整的飞书Webhook地址 (留空则不转发到飞书)

allsms = switch,true,tag=转发所有短信,desc=开启则转发所有短信，关闭则仅转发匹配正则的短信
regexstr = input,"码|碼|code|\\d{4,}",tag=正则匹配规则,desc=用于匹配验证码短信的正则表达式（需转义）
sender_filter = input,"",tag=发信人号码过滤,desc=只转发指定发信人的短信，多个号码用逗号分隔，留空则不过滤
debug_mode = switch,false,tag=调试模式,desc=开启后显示详细的调试信息和通知
retry_count = select,"1","2","3",tag=重试次数,desc=网络请求失败时的重试次数
timeout_seconds = select,"10","20","30",tag=请求超时,desc=网络请求的超时时间（秒）

[Script]
http-request ^https?:\/\/jprx\.m\.qq\.com\/forward.* script-path=https://gh-proxy.org/https://raw.githubusercontent.com/akinachann/SMSForwarder_LOON/refs/heads/main/get_sms.js, requires-body=true, timeout=20, enable=true, tag=获取腾讯手机管家短信转发, argument=[{tg_token},{feishu_token},{allsms},{regexstr},{sender_filter},{debug_mode},{retry_count},{timeout_seconds}]

[MITM]
hostname = jprx.m.qq.com
